{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": [
    "tests/**/*",
    "server/src/**/*",
    "client/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "out"
  ]
}
